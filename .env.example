TRUSTAI_BATCH_SEAL_SECONDS=300
TRUSTAI_CREDIT_RATE=0.01
TRUSTAI_CORS_ORIGINS=http://localhost:3000,http://localhost:3001
TRUSTAI_JWT_SECRET=change-me-in-production
TRUSTAI_JWT_EXPIRE_HOURS=24
TRUSTAI_ADMIN_EMAIL=admin@trustai.local
TRUSTAI_ADMIN_PASSWORD=admin123
