# PostgreSQL
POSTGRES_USER=trustai
POSTGRES_PASSWORD=trustai
POSTGRES_DB=trustai
DATABASE_URL=postgresql+asyncpg://trustai:trustai@postgres:5432/trustai

# Backend
TRUSTAI_MODEL_PATH=/app/models/Qwen2.5-Coder-0.5B-Instruct-Q8_0.gguf
TRUSTAI_INFERENCE_BACKEND=lmstudio
TRUSTAI_LMSTUDIO_URL=http://localhost:1234/v1
TRUSTAI_SIGNING_KEY_PATH=/app/secrets/signing_key.pem
TRUSTAI_SIGNING_KEY_ID=trustai-signing-v1
