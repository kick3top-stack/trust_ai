# VPS / local run (no Docker, no PostgreSQL)
# Copy to .env and set values for your deployment.
#
# Vercel frontend + Windows VPS backend (no domain):
#   TRUSTAI_CORS_ORIGINS=https://your-app.vercel.app
#   On Vercel set: TRUSTAI_BACKEND_URL=http://YOUR_VPS_PUBLIC_IP:8000
#   On Vercel set: NEXT_PUBLIC_API_URL=/api/v1
#
# All on VPS with public IP only (no domain):
#   TRUSTAI_PUBLIC_HOST=http://YOUR_VPS_PUBLIC_IP:3000
#   TRUSTAI_CORS_ORIGINS=http://YOUR_VPS_PUBLIC_IP:3000

DATABASE_URL=sqlite+aiosqlite:///./data/trustai.db

TRUSTAI_MODEL_PATH=models/Qwen2.5-Coder-0.5B-Instruct-Q8_0.gguf
TRUSTAI_INFERENCE_BACKEND=lmstudio
TRUSTAI_LMSTUDIO_URL=http://localhost:1234/v1
TRUSTAI_SIGNING_KEY_PATH=secrets/signing_key.pem
TRUSTAI_SIGNING_KEY_ID=trustai-signing-v1
TRUSTAI_BATCH_SIZE=1
TRUSTAI_BATCH_SEAL_SECONDS=300
TRUSTAI_CREDIT_RATE=0.01

# Replace with your VPS public IP or domain (e.g. http://203.0.113.10:3000)
# For Vercel-only UI, leave localhost and set TRUSTAI_CORS_ORIGINS to your Vercel URL instead.
TRUSTAI_PUBLIC_HOST=http://localhost:3000
TRUSTAI_BACKEND_PORT=8000
# Vercel example: TRUSTAI_CORS_ORIGINS=https://your-app.vercel.app
TRUSTAI_CORS_ORIGINS=http://localhost:3000,http://localhost:3001

NEXT_PUBLIC_API_URL=/api/v1
